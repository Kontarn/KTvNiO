@using KTvNiO.Models
@model List<TestQuestion>

@{
    ViewData["Title"] = "Тестирование: " + ViewBag.Course.Title;
}

<div class="container mt-5">
    <nav aria-label="breadcrumb" class="mb-4 fade-in">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")" class="text-decoration-none">Главная</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Details", "Courses", new { id = ViewBag.Course.Id })" class="text-decoration-none">@ViewBag.Course.Title</a></li>
            <li class="breadcrumb-item active" aria-current="page">Тестирование</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0 interactive-card fade-in mb-4">
        <div class="card-header bg-primary text-white py-3">
            <h2 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Тестирование по курсу "@ViewBag.Course.Title"</h2>
        </div>
        <div class="card-body p-4">
            <form asp-controller="Tests" asp-action="SubmitTest" method="post" id="testForm">
                <input type="hidden" name="courseId" value="@ViewBag.Course.Id" />
                
                <div class="alert alert-info mb-4">
                    <i class="bi bi-info-circle me-2"></i>Выберите один правильный вариант ответа для каждого вопроса
                </div>

                @for (int i = 0; i < Model.Count; i++)
                {
                    var question = Model[i];
                    <div class="card mb-4 border-0 shadow-sm question-card interactive-card">
                        <div class="card-header bg-light py-3">
                            <h5 class="mb-0 fw-bold"><span class="badge bg-primary me-2">Вопрос @(i + 1)</span></h5>
                        </div>
                        <div class="card-body">
                            <p class="lead mb-4">@question.QuestionText</p>
                            
                            <div class="list-group">
                                <label class="list-group-item list-group-item-action d-flex gap-3 py-3 interactive-option" style="cursor: pointer;">
                                    <input class="form-check-input flex-shrink-0" type="radio" name="answers[@question.Id]" value="A" id="q@(question.Id)_a">
                                    <div class="pt-1 form-checked-content">
                                        <strong>Вариант A</strong>
                                        <p class="mb-0 opacity-75">@question.OptionA</p>
                                    </div>
                                </label>
                                
                                <label class="list-group-item list-group-item-action d-flex gap-3 py-3 interactive-option" style="cursor: pointer;">
                                    <input class="form-check-input flex-shrink-0" type="radio" name="answers[@question.Id]" value="B" id="q@(question.Id)_b">
                                    <div class="pt-1 form-checked-content">
                                        <strong>Вариант B</strong>
                                        <p class="mb-0 opacity-75">@question.OptionB</p>
                                    </div>
                                </label>
                                
                                @if (!string.IsNullOrEmpty(question.OptionC))
                                {
                                    <label class="list-group-item list-group-item-action d-flex gap-3 py-3 interactive-option" style="cursor: pointer;">
                                        <input class="form-check-input flex-shrink-0" type="radio" name="answers[@question.Id]" value="C" id="q@(question.Id)_c">
                                        <div class="pt-1 form-checked-content">
                                            <strong>Вариант C</strong>
                                            <p class="mb-0 opacity-75">@question.OptionC</p>
                                        </div>
                                    </label>
                                }
                                
                                @if (!string.IsNullOrEmpty(question.OptionD))
                                {
                                    <label class="list-group-item list-group-item-action d-flex gap-3 py-3 interactive-option" style="cursor: pointer;">
                                        <input class="form-check-input flex-shrink-0" type="radio" name="answers[@question.Id]" value="D" id="q@(question.Id)_d">
                                        <div class="pt-1 form-checked-content">
                                            <strong>Вариант D</strong>
                                            <p class="mb-0 opacity-75">@question.OptionD</p>
                                        </div>
                                    </label>
                                }
                            </div>
                        </div>
                    </div>
                }
                
                <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-4">
                    <button type="submit" class="btn btn-success btn-lg px-5 interactive-btn">
                        <i class="bi bi-check-circle me-2"></i>Завершить тестирование
                    </button>
                    <a asp-controller="Courses" asp-action="Learn" asp-route-id="@ViewBag.Course.Id" class="btn btn-outline-secondary btn-lg px-4 interactive-btn">
                        <i class="bi bi-arrow-left me-2"></i>Вернуться к материалу
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
